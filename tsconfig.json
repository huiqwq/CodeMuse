{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "NodeNext",
                            "moduleResolution":  "NodeNext",
                            "strict":  true,
                            "noEmit":  true,
                            "allowImportingTsExtensions":  true,
                            "erasableSyntaxOnly":  true,
                            "skipLibCheck":  true,
                            "types":  [
                                          "node"
                                      ]
                        },
    "include":  [
                    "src/**/*.ts",
                    "tests/**/*.ts"
                ]
}
