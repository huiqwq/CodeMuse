# Configure these in your terminal before starting CodeMuse.
# Never commit a real API key. CodeMuse does not automatically load this file.

# Presets: deepseek or glm. Any other name is treated as a custom
# OpenAI-compatible provider when CODEMUSE_BASE_URL and CODEMUSE_MODEL are set.
CODEMUSE_PROVIDER=deepseek
CODEMUSE_API_KEY=
CODEMUSE_BASE_URL=https://api.deepseek.com
CODEMUSE_MODEL=deepseek-chat

# GLM example:
# CODEMUSE_PROVIDER=glm
# CODEMUSE_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# CODEMUSE_MODEL=glm-4-flash

# Custom OpenAI-compatible example:
# CODEMUSE_PROVIDER=custom
# CODEMUSE_BASE_URL=https://example.com/v1
# CODEMUSE_MODEL=provider-model-name

# Approximate token budget for task-specific code snippets (500-100000).
CODEMUSE_CONTEXT_TOKENS=6000

# Force the deterministic local demo even when an API key exists.
CODEMUSE_MOCK=0
