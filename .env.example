# CodeMuse reads environment variables from the terminal process.
# It does not automatically load this file. Never put a real API key in Git.

# Recommended multi-profile API Key variables used by ~/.codemuse/config.json.
DEEPSEEK_API_KEY=
ZHIPUAI_API_KEY=
OPENAI_API_KEY=

# Built-in GLM profiles share ZHIPUAI_API_KEY:
# glm uses glm-5.2; glm-flash uses glm-4.7-flash.

# Optional active profile from the local config file.
CODEMUSE_PROFILE=

# Optional local profile config override.
# Default on Windows: C:\Users\<you>\.codemuse\config.json
CODEMUSE_CONFIG_PATH=

# Optional encrypted credential file override.
# Default on Windows: C:\Users\<you>\.codemuse\credentials.json
CODEMUSE_CREDENTIALS_PATH=

# Legacy single-provider configuration remains supported.
CODEMUSE_PROVIDER=deepseek
CODEMUSE_API_KEY=
CODEMUSE_BASE_URL=https://api.deepseek.com
CODEMUSE_MODEL=deepseek-chat

# Request policy: timeout 5000-120000 ms, retries 0-5.
CODEMUSE_TIMEOUT_MS=30000
CODEMUSE_MAX_RETRIES=2

# Approximate token budget for task-specific code snippets (500-100000).
CODEMUSE_CONTEXT_TOKENS=6000

# Force the deterministic local demo even when API keys exist.
CODEMUSE_MOCK=0
