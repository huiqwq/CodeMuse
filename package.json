{
  "name": "codemuse-cli",
  "version": "1.0.0",
  "description": "A local, multi-model coding agent for your terminal.",
  "type": "module",
  "bin": {
    "codemuse": "./src/cli.ts"
  },
  "files": [
    "src",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "node src/cli.ts",
    "start": "node src/cli.ts",
    "test": "node tests/run.ts",
    "check": "node --check src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "npm test && npm run typecheck && npm run check"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^7.0.2"
  }
}
